{
  "expo": {
    "name": "Hora do Remédio",
    "slug": "hora-do-remedio",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "horadoremedio",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "br.com.flavioviolato.horadoremedio",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "O app usa a câmera para você fotografar a caixinha do remédio.",
        "NSPhotoLibraryUsageDescription": "O app acessa suas fotos para você escolher a imagem da caixinha do remédio.",
        "NSAlarmKitUsageDescription": "O app agenda alarmes para lembrar você de tomar seus remédios na hora certa, mesmo com o iPhone no silencioso."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#175A41",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F7F4EC",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 140
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "./plugins/withAlarmSounds.js",
        {
          "soundsDir": "assets/sounds"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "26.0"
          }
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
